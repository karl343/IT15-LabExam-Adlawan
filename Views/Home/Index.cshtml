@{
    ViewData["Title"] = "HR Payroll Management System";
}

<div class="text-center py-5">
    <div style="width:80px;height:80px;border-radius:20px;background:linear-gradient(135deg,#1e3a8a,#3b82f6);display:flex;align-items:center;justify-content:center;color:white;font-size:2rem;margin:0 auto 1.5rem;">
        <i class="bi bi-briefcase-fill"></i>
    </div>
    <h1 class="display-5 fw-bold text-dark mb-4">HR Payroll Management System</h1>
    <div class="d-flex gap-3 justify-content-center">
        <a asp-controller="Employees" asp-action="Index" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-people-fill me-2"></i> Manage Employees
        </a>
        <a asp-controller="Payrolls" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">
            <i class="bi bi-cash-stack me-2"></i> View Payrolls
        </a>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size:2.5rem;margin-bottom:0.75rem;">👥</div>
            <h5 class="fw-bold mb-4">Employee Management</h5>
            <a asp-controller="Employees" asp-action="Create" class="btn btn-sm btn-outline-primary mt-auto">Add Employee</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size:2.5rem;margin-bottom:0.75rem;">💰</div>
            <h5 class="fw-bold mb-4">Payroll Processing</h5>
            <a asp-controller="Payrolls" asp-action="Create" class="btn btn-sm btn-outline-primary mt-auto">Add Payroll</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size:2.5rem;margin-bottom:0.75rem;">📊</div>
            <h5 class="fw-bold mb-4">Payroll Summary</h5>
            <a asp-controller="Payrolls" asp-action="Index" class="btn btn-sm btn-outline-primary mt-auto">View Summary</a>
        </div>
    </div>
</div>
