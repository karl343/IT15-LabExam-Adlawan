@model crud_it15.Models.Payroll

@{
    ViewData["Title"] = "Edit Payroll Record";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-pencil-fill me-2 text-primary"></i>Edit Payroll Record</h1>
        <p class="page-subtitle">Update the payroll details. Gross Pay and Net Pay will be recalculated.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0 fw-semibold">Payroll Information</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="PayrollId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="EmployeeId" class="form-label"></label>
                            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeId" class="form-select">
                                <option value="">— Select Employee —</option>
                            </select>
                            <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Date" class="form-label"></label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DaysWorked" class="form-label"></label>
                            <input asp-for="DaysWorked" class="form-control" type="number" step="0.5" min="0" />
                            <span asp-validation-for="DaysWorked" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Deduction" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="Deduction" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Deduction" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Current Gross Pay</label>
                            <div class="form-control bg-light fw-semibold text-success">
                                ₱@Model.GrossPay.ToString("N2")
                            </div>
                            <small class="text-muted">Will be recalculated on save</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Current Net Pay</label>
                            <div class="form-control bg-light fw-semibold text-success">
                                ₱@Model.NetPay.ToString("N2")
                            </div>
                            <small class="text-muted">Will be recalculated on save</small>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="alert alert-info d-flex align-items-center gap-2" style="border-radius:10px;">
                        <i class="bi bi-info-circle-fill"></i>
                        <div>
                            Gross Pay = Days Worked × Employee Daily Rate &nbsp;|&nbsp;
                            Net Pay = Gross Pay − Deduction
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
