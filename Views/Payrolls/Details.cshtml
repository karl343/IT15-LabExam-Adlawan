@model crud_it15.Models.Payroll

@{
    ViewData["Title"] = "Payroll Details";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-receipt me-2 text-primary"></i>Payroll Details</h1>
        <p class="page-subtitle">Full payroll record breakdown.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span class="fw-semibold">Payroll #@Model.PayrollId</span>
                <span class="badge bg-success">@Model.Date.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="card-body p-4">

                <!-- Employee info -->
                <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background:#f0f7ff;">
                    <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#1d4ed8);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:1rem;flex-shrink:0;">
                        @Model.Employee?.FirstName[0]@Model.Employee?.LastName[0]
                    </div>
                    <div>
                        <div class="fw-bold fs-6">@Model.Employee?.FullName</div>
                        <div class="text-muted small">
                            @Model.Employee?.Position &bull; @Model.Employee?.Department
                        </div>
                        <div class="text-muted small">Daily Rate: <strong class="text-success">₱@Model.Employee?.DailyRate.ToString("N2")</strong></div>
                    </div>
                </div>

                <hr />

                <!-- Payroll breakdown -->
                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted fw-medium">Days Worked</td>
                        <td class="text-end fw-semibold">@Model.DaysWorked days</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-medium">Daily Rate</td>
                        <td class="text-end fw-semibold">₱@Model.Employee?.DailyRate.ToString("N2")</td>
                    </tr>
                    <tr class="border-top">
                        <td class="fw-bold">Gross Pay</td>
                        <td class="text-end fw-bold">₱@Model.GrossPay.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="text-danger fw-medium">Deduction</td>
                        <td class="text-end text-danger fw-semibold">- ₱@Model.Deduction.ToString("N2")</td>
                    </tr>
                    <tr class="border-top" style="background:#f0fdf4;">
                        <td class="fw-bold text-success fs-5">Net Pay</td>
                        <td class="text-end fw-bold text-success fs-5">₱@Model.NetPay.ToString("N2")</td>
                    </tr>
                </table>

                <div class="d-flex gap-2 justify-content-end mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.PayrollId" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.PayrollId" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
